#!/usr/bin/env python3
"""Read external EDID via I2C. Called by hdmi-edid config merge."""
import subprocess, sys

bus = sys.argv[1] if len(sys.argv) > 1 else '13'
data = bytearray(256)
for a in range(256):
    r = subprocess.run(['i2cget', '-y', bus, '0x50', str(a)],
                       capture_output=True, text=True)
    if r.returncode == 0:
        data[a] = int(r.stdout.strip(), 16)

if data[:8] != bytes([0, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0]):
    print("ERROR: Invalid EDID header")
    sys.exit(1)

# Display name
name = "Display"
for dtd_off in [54, 72, 90, 108]:
    if dtd_off + 18 > 128:
        break
    dtd = data[dtd_off:dtd_off+18]
    if dtd[0:2] == bytes([0, 0]) and dtd[3] == 0xFC:
        name = dtd[5:18].decode('ascii', 'ignore').strip('\x00\x0a\x20')
        break

# Extract VICs
vics = []
if len(data) >= 256 and data[128] == 2:
    off = data[130]
    pos = 4
    while pos < off:
        tag = (data[128+pos] >> 5) & 7
        length = data[128+pos] & 31
        if tag == 2:  # Video Data Block
            n = data[128+pos+1]
            for i in range(n):
                vics.append(data[128+pos+2+i])
        pos += 1 + length

print(f"Display: {name}")
print(f"VICs: {vics}")
print(f"EDID size: {len(data)}B")
