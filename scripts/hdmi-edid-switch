#!/bin/bash
# hdmi-edid-switch — auto-detect and switch EDID mode
# Clears override, reads DDC: if real EDID exists → use it; else → apply fake
set -euo pipefail
C="HDMI-A-1"
E="/sys/class/drm/card1-${C}/edid"
O="/sys/kernel/debug/dri/1/${C}/edid_override"
S="/sys/class/drm/card1-${C}/status"
F="/lib/firmware/edid-hdmi-audio.bin"

echo "=== HDMI EDID Switch ==="

# Clear override, read DDC
echo -n reset > "$O" 2>/dev/null || true
echo detect > "$S" 2>/dev/null || true
sleep 0.5

# Check DDC
TMP=$(mktemp)
cat "$E" > "$TMP" 2>/dev/null || true
SZ=$(wc -c < "$TMP")
rm -f "$TMP"

if [ "$SZ" -ge 256 ]; then
    echo "Real EDID detected (${SZ}B) — using hardware EDID"
    echo "Modes:"
    cat /sys/class/drm/card1-${C}/modes 2>/dev/null | grep -E '^[0-9]' | sort -t x -k1 -nr | uniq | head -10
else
    echo "No real EDID (${SZ}B) — applying fake EDID"
    cat "$F" > "$O"
    echo detect > "$S" 2>/dev/null || true
    sleep 0.3
    echo "Modes: $(cat /sys/class/drm/card1-${C}/modes 2>/dev/null | head -3 | tr '
' ' ')"
    echo "Audio: $(aplay -D plughw:vc4hdmi0 /usr/share/sounds/alsa/Front_Center.wav 2>&1 | tail -1)"
fi
