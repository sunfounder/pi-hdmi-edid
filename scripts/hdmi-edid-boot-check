#!/bin/bash
# hdmi-edid-boot-check — boot-time EDID check
set -euo pipefail
C="HDMI-A-1"
E="/sys/class/drm/card1-${C}/edid"
O="/sys/kernel/debug/dri/1/${C}/edid_override"
S="/sys/class/drm/card1-${C}/status"
F="/lib/firmware/edid-hdmi-audio.bin"

for i in $(seq 1 30); do
    if [ -f "$E" ]; then break; fi
    sleep 1
done

# Read EDID to temp file (bash $() strips null bytes)
TMP=$(mktemp)
cat "$E" > "$TMP" 2>/dev/null || true
SZ=$(wc -c < "$TMP")
rm -f "$TMP"

if [ "$SZ" -ge 256 ]; then
    logger -t hdmi-edid-boot "Real EDID found (${SZ}B). No override needed."
    exit 0
fi

logger -t hdmi-edid-boot "No EDID (${SZ}B). Applying fake EDID."
if [ -f "$F" ] && [ -w "$O" ]; then
    cat "$F" > "$O"
    echo detect > "$S" 2>/dev/null || true
    logger -t hdmi-edid-boot "Fake EDID applied."
fi
