#!/bin/bash
# hdmi-edid-rollback — restore original config
set -euo pipefail
echo "=== HDMI EDID 回滚 ==="

# 1. Restore cmdline
if [ -f /boot/firmware/cmdline.txt.bak ]; then
    cp /boot/firmware/cmdline.txt.bak /boot/firmware/cmdline.txt
    echo "[1/5] cmdline restored"
else
    sed -i 's/ vc4.force_hotplug=1//' /boot/firmware/cmdline.txt
    echo "[1/5] vc4.force_hotplug removed"
fi

# 2. Remove services
systemctl disable hdmi-edid-boot.service 2>/dev/null || true
systemctl stop hdmi-edid-boot.service 2>/dev/null || true
rm -f /etc/systemd/system/hdmi-edid-boot.service
rm -f /etc/systemd/system/hdmi-reprobe.service /etc/systemd/system/hdmi-reprobe.timer
systemctl daemon-reload
echo "[2/5] services removed"

# 3. Clear EDID override
echo -n reset > /sys/kernel/debug/dri/1/HDMI-A-1/edid_override 2>/dev/null || true
echo "[3/5] EDID override cleared"

# 4. Remove scripts
rm -f /usr/local/bin/hdmi-edid-boot-check /usr/local/bin/hdmi-fake-edid
rm -f /usr/local/bin/hdmi-real-edid /usr/local/bin/hdmi-edid-reprobe
echo "[4/5] scripts removed"

# 5. Restore config.txt hdmi_force_hotplug
sed -i '/^hdmi_force_hotplug=1/d' /boot/firmware/config.txt 2>/dev/null || true
echo "[5/5] config.txt cleaned"

echo ""
echo "Done. Reboot: shutdown -r now"
