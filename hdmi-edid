#!/bin/bash
# hdmi-edid — HDMI EDID runtime management for Raspberry Pi 5
# Usage: hdmi-edid switch|config|uninstall
# Auto-detects DRM card/debugfs paths — no hardcoded card numbers.
set -euo pipefail

F="/lib/firmware/edid-hdmi-audio.bin"
CMDLINE="/boot/firmware/cmdline.txt"
CONFIG_TXT="/boot/firmware/config.txt"

usage() {
    echo "Usage: hdmi-edid switch|config|uninstall"
    echo ""
    echo "  switch    Auto-detect and switch EDID mode (real or fake)"
    echo "  config    Select fake EDID resolution interactively"
    echo "  uninstall Remove all configuration (restore original state)"
    exit 1
}

need_root() {
    [ "$(id -u)" -eq 0 ] || { echo "ERROR: must run as root"; exit 1; }
}

# Auto-detect DRM paths for HDMI-A-1 connector
detect_paths() {
    for i in $(seq 1 30); do
        E=$(ls /sys/class/drm/card*-HDMI-A-1/edid 2>/dev/null | head -1)
        O=$(ls /sys/kernel/debug/dri/*/HDMI-A-1/edid_override 2>/dev/null | head -1)
        [ -n "$E" ] && [ -n "$O" ] && break
        sleep 1
    done
    S="${E%edid}status"

    if [ -z "$E" ] || [ -z "$O" ]; then
        echo "ERROR: cannot find HDMI-A-1 connector after 30s"
        echo "  E=$E"
        echo "  O=$O"
        exit 1
    fi
}

# ─── switch ────────────────────────────────────────────────────────
do_switch() {
    detect_paths
    echo "=== HDMI EDID Switch ==="
    echo ""

    # Clear override, read DDC
    echo -n reset > "$O" 2>/dev/null || true
    echo detect > "$S" 2>/dev/null || true
    sleep 0.5

    TMP=$(mktemp)
    cat "$E" > "$TMP" 2>/dev/null || true
    SZ=$(wc -c < "$TMP")
    rm -f "$TMP"

    if [ "$SZ" -ge 256 ]; then
        echo "Real EDID detected (${SZ}B) — using hardware EDID"
        echo "Modes:"
        cat "${E%edid}modes" 2>/dev/null | grep '^[0-9]' | sort -t x -k1 -nr | uniq | head -10
    else
        echo "No real EDID (${SZ}B) — applying fake EDID (1080p+audio)"
        cat "$F" > "$O" 2>/dev/null
        echo detect > "$S" 2>/dev/null || true
        sleep 0.3
        echo "Modes: $(cat "${E%edid}modes" 2>/dev/null | head -3 | tr '\n' ' ')"
    fi

    # Restart desktop audio services
    for uid in $(loginctl list-users --no-legend 2>/dev/null | awk '{print $1}'); do
        systemctl --user -M "${uid}@.host" restart pipewire pipewire-pulse wireplumber 2>/dev/null || true
    done
    killall wf-panel-pi 2>/dev/null || true
    echo ""
    echo "Audio services refreshed."
}

# ─── config ────────────────────────────────────────────────────────
do_config() {
    need_root
    echo "=== HDMI EDID Resolution Config ==="
    echo ""
    echo "Select fake EDID preferred resolution:"
    echo ""
    echo "  ── 1080p ──            ── 4K ──"
    echo "   1) 1920x1080 @24Hz     12) 3840x2160 @24Hz"
    echo "   2) 1920x1080 @25Hz     13) 3840x2160 @25Hz"
    echo "   3) 1920x1080 @30Hz     14) 3840x2160 @30Hz"
    echo "   4) 1920x1080 @50Hz     15) 3840x2160 @50Hz"
    echo "   5) 1920x1080 @60Hz *   16) 3840x2160 @60Hz"
    echo ""
    echo "  ── 1080i ──            ── PC / Other ──"
    echo "   6) 1920x1080i@50Hz     17) 1280x720  @60Hz"
    echo "   7) 1920x1080i@60Hz     18) 1280x720  @50Hz"
    echo "                          19) 1280x800  @60Hz"
    echo "  ── 2K ──               20) 1360x768  @60Hz"
    echo "   8) 2560x1440 @60Hz     21) 1440x900  @60Hz"
    echo "   9) 2560x1600 @60Hz     22) 1600x900  @60Hz"
    echo "                          23) 1680x1050 @60Hz"
    echo "  ── Ultrawide ──        24) 1920x1200 @60Hz"
    echo "  10) 2560x1080 @60Hz     25) 640x480   @60Hz"
    echo "  11) 3440x1440 @60Hz     26) 720x480   @60Hz"
    echo ""
    echo "  * = default"
    echo ""
    printf "Enter number [1-26]: "
    read -r choice

    case "$choice" in
        1)  MODE="1080p24" ;;
        2)  MODE="1080p25" ;;
        3)  MODE="1080p30" ;;
        4)  MODE="1080p50" ;;
        5)  MODE="1080p60" ;;
        6)  MODE="1080i50" ;;
        7)  MODE="1080i60" ;;
        8)  MODE="1440p60" ;;
        9)  MODE="1600p60" ;;
        10) MODE="2560x1080p60" ;;
        11) MODE="3440x1440p60" ;;
        12) MODE="4k24" ;;
        13) MODE="4k25" ;;
        14) MODE="4k30" ;;
        15) MODE="4k50" ;;
        16) MODE="4k60" ;;
        17) MODE="720p60" ;;
        18) MODE="720p50" ;;
        19) MODE="800p60" ;;
        20) MODE="768p60" ;;
        21) MODE="900p60" ;;
        22) MODE="900p60_1600" ;;
        23) MODE="1050p60" ;;
        24) MODE="1200p60" ;;
        25) MODE="480p60" ;;
        26) MODE="480p60_720" ;;
        *) echo "Invalid choice"; exit 1 ;;
    esac

    echo ""
    echo "Generating fake EDID with $MODE..."

    python3 << PYEOF
import struct, sys

mode = "$MODE"

# DTD parameters: (pclk_10kHz, H_active, H_blank, H_offset, H_width,
#                   V_active, V_blank, V_offset, V_width, H_pol, V_pol)
# H_pol: 1=positive, 0=negative; V_pol: 1=positive, 0=negative
timings = {
    # 1080p CEA-861
    "1080p24":  ( 7425, 1920, 830, 638, 44, 1080, 45, 4, 5, 1, 1),
    "1080p25":  ( 7425, 1920, 720, 528, 44, 1080, 45, 4, 5, 1, 1),
    "1080p30":  ( 7425, 1920, 280, 88, 44, 1080, 45, 4, 5, 1, 1),
    "1080p50":  (14850, 1920, 720, 528, 44, 1080, 45, 4, 5, 1, 1),
    "1080p60":  (14850, 1920, 280, 88, 44, 1080, 45, 4, 5, 1, 1),
    # 1080i (field height = V_active/2)
    "1080i50":  ( 7425, 1920, 720, 528, 44, 540, 22, 2, 5, 1, 1),
    "1080i60":  ( 7425, 1920, 280, 88, 44, 540, 22, 2, 5, 1, 1),
    # 2K (CVT-RB)
    "1440p60":  (24150, 2560, 160, 48, 32, 1440, 41, 3, 5, 0, 0),
    "1600p60":  (26850, 2560, 160, 48, 32, 1600, 46, 3, 6, 0, 0),
    # Ultrawide
    "2560x1080p60":  (18560, 2560, 160, 48, 32, 1080, 42, 3, 5, 0, 0),
    "3440x1440p60":  (31975, 3440, 160, 48, 32, 1440, 41, 3, 5, 0, 0),
    # 4K CEA-861
    "4k24":     (29700, 3840, 1660, 1276, 88, 2160, 90, 8, 10, 1, 1),
    "4k25":     (29700, 3840, 1440, 1056, 88, 2160, 90, 8, 10, 1, 1),
    "4k30":     (29700, 3840, 560, 176, 88, 2160, 90, 8, 10, 1, 1),
    "4k50":     (59400, 3840, 1440, 1056, 88, 2160, 90, 8, 10, 1, 1),
    "4k60":     (59400, 3840, 560, 176, 88, 2160, 90, 8, 10, 1, 1),
    # 720p
    "720p60":   ( 7425, 1280, 370, 110, 40, 720, 30, 5, 5, 1, 1),
    "720p50":   ( 7425, 1280, 700, 440, 40, 720, 30, 5, 5, 1, 1),
    # PC resolutions (CVT-RB)
    "800p60":   ( 7100, 1280, 160, 48, 32, 800, 23, 3, 6, 0, 0),
    "768p60":   ( 8550, 1360, 432, 64, 112, 768, 27, 3, 6, 1, 1),
    "900p60":   (10650, 1440, 464, 80, 152, 900, 34, 3, 6, 0, 0),
    "900p60_1600": (10800, 1600, 160, 48, 32, 900, 34, 3, 6, 0, 0),
    "1050p60":  (14625, 1680, 560, 104, 176, 1050, 39, 3, 6, 0, 0),
    "1200p60":  (15400, 1920, 160, 48, 32, 1200, 35, 3, 6, 0, 0),
    # Low resolutions
    "480p60":   ( 2518, 640, 160, 16, 96, 480, 45, 10, 2, 0, 0),
    "480p60_720": ( 2700, 720, 138, 16, 62, 480, 45, 9, 6, 0, 0),
}

pclk, ha, hb, hso, hsw, va, vb, vso, vsw, hp, vp = timings[mode]

edid = bytearray(256)
CEA = 128

# ---- Block 0: Base EDID ----
edid[0:8]   = bytes([0x00,0xFF,0xFF,0xFF,0xFF,0xFF,0xFF,0x00])
edid[8:10]  = bytes([0x48,0xF2])  # Manufacturer ID
edid[10:12] = struct.pack('<H', 1)
edid[12:16] = struct.pack('<I', 1)
edid[16]    = 26   # week
edid[17]    = 35   # year-1990
edid[18]    = 0x01
edid[19]    = 0x04
edid[20]    = 0xA5
edid[21:23] = bytes([0x00,0x00])
edid[23]    = 0x78
edid[24]    = 0x0E
edid[25:35] = bytes([0xEE,0x91,0xA3,0x54,0x4C,0x99,0x26,0x0F,0x50,0x54])
edid[35:38] = bytes([0x21,0x08,0x00])

# Fill standard timings with unused
for i in range(38, 54, 2):
    edid[i] = 0x01; edid[i+1] = 0x01

# DTD 1: Preferred timing
pclk_raw = pclk
edid[54:56] = struct.pack('<H', pclk_raw)
edid[56] = ha & 0xFF
edid[57] = hb & 0xFF
edid[58] = ((ha>>8)&0xF)<<4 | ((hb>>8)&0xF)
edid[59] = va & 0xFF
edid[60] = vb & 0xFF
edid[61] = ((va>>8)&0xF)<<4 | ((vb>>8)&0xF)
edid[62] = hso & 0xFF
edid[63] = hsw & 0xFF
edid[64] = ((vso&0xF)<<4) | (vsw&0xF)
edid[65] = ((hso>>8)&0x3)<<2 | ((hsw>>8)&0x3)
edid[66:72] = bytes([0x00,0x00,0x00,0x18,0x00,0x00])

# DTD 2: unused, fill with zeros
for i in range(72, 90):
    edid[i] = 0x00

# Display name
edid[90:108] = bytes([0x00,0x00,0x00,0xFC,0x00,
    0x48,0x44,0x4D,0x49,0x2D,0x45,0x44,0x49,0x44,0x0A,0x20,0x20,0x20])

# Range limits
edid[108:126] = bytes([0x00,0x00,0x00,0xFD,0x00,
    57,63,30,85,0xAA,0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00])

edid[126] = 0x01  # 1 extension block
edid[127] = (256 - sum(edid[:127])) & 0xFF

# ---- Block 1: CEA-861 Extension ----
edid[CEA+0] = 0x02   # CEA-861 tag
edid[CEA+1] = 0x03   # revision

pos = 4  # data block collection start

# Audio: LPCM 2ch, 32/44.1/48kHz, 16/20/24bit
edid[CEA+pos]   = (1<<5)|3    # Audio Data Block, 3 bytes payload
edid[CEA+pos+1] = 0x09        # PCM, 2ch
edid[CEA+pos+2] = 0x07        # 32/44.1/48 kHz
edid[CEA+pos+3] = 0x07        # 16/20/24 bit
pos += 4

# Speaker: FL/FR
edid[CEA+pos]   = (4<<5)|3
edid[CEA+pos+1] = 0x00
edid[CEA+pos+2] = 0x00
edid[CEA+pos+3] = 0x01
pos += 4

# Vendor: HDMI (IEEE OUI 0x000C03)
edid[CEA+pos]   = (3<<5)|5
edid[CEA+pos+1] = 0x03
edid[CEA+pos+2] = 0x0C
edid[CEA+pos+3] = 0x00
edid[CEA+pos+4] = 0x10   # PA=1.0.0.0, supports_ai=1
edid[CEA+pos+5] = 0x00
pos += 6

edid[CEA+2] = pos     # DTD offset
edid[CEA+3] = 0x00    # 0 native DTDs in extension

for i in range(pos, 127):
    edid[CEA+i] = 0x00
edid[CEA+127] = (256 - sum(edid[CEA:CEA+127])) & 0xFF

with open("$F", 'wb') as f:
    f.write(bytes(edid))

cs0 = (256 - sum(edid[:127])) & 0xFF
cs1 = (256 - sum(edid[128:255])) & 0xFF
print(f"  Block0 checksum: 0x{cs0:02x} {'OK' if cs0==edid[127] else 'FAIL'}")
print(f"  Block1 checksum: 0x{cs1:02x} {'OK' if cs1==edid[255] else 'FAIL'}")
print(f"  File size: {len(edid)} bytes")
PYEOF

    echo ""
    echo "Fake EDID updated: $MODE"

    # Check if we're on Path B (drm.edid_firmware in cmdline)
    if grep -q 'drm.edid_firmware' /proc/cmdline 2>/dev/null; then
        echo "  Path B detected: reboot required for new resolution."
        echo "  Run: sudo systemctl reboot"
    else
        echo "  Path A detected: run 'hdmi-edid switch' to apply."
        echo "  Or reboot for boot-time application."
    fi
}

# ─── uninstall ─────────────────────────────────────────────────────
do_uninstall() {
    detect_paths
    echo "=== HDMI EDID Uninstall ==="
    echo ""

    # Restore cmdline: remove both params
    if [ -f "${CMDLINE}.bak" ]; then
        cp "${CMDLINE}.bak" "$CMDLINE"
    else
        sed -i 's/ vc4.force_hotplug=1//' "$CMDLINE"
        sed -i 's/ drm.edid_firmware=HDMI-A-1:edid-hdmi-audio.bin//' "$CMDLINE"
    fi
    echo "[1/3] cmdline restored"

    sed -i '/^hdmi_force_hotplug=1/d' "$CONFIG_TXT" 2>/dev/null || true
    echo "[2/3] config.txt cleaned"

    systemctl disable hdmi-edid-boot.service 2>/dev/null || true
    systemctl stop hdmi-edid-boot.service 2>/dev/null || true
    rm -f /etc/systemd/system/hdmi-edid-boot.service
    systemctl daemon-reload
    echo -n reset > "$O" 2>/dev/null || true
    echo detect > "$S" 2>/dev/null || true
    echo "[3/3] service removed, EDID override cleared"

    echo ""
    echo "Uninstall complete. Reboot to fully apply."
}

# ─── main ──────────────────────────────────────────────────────────
case "${1:-}" in
    switch)   need_root; do_switch ;;
    config)   do_config ;;
    uninstall) need_root; do_uninstall ;;
    *)        usage ;;
esac
