#!/bin/bash
# hdmi-edid — HDMI EDID runtime management for Raspberry Pi 5
set -euo pipefail

F="/lib/firmware/edid-hdmi-audio.bin"
CMDLINE="/boot/firmware/cmdline.txt"
CONFIG_TXT="/boot/firmware/config.txt"

usage() {
    echo "Usage: hdmi-edid switch|config|uninstall"
    echo ""
    echo "  switch    Auto-detect and switch EDID mode (real or fake)"
    echo "  config    Manage EDID resolutions interactively"
    echo "  uninstall Remove all configuration (restore original state)"
    exit 1
}

need_root() {
    [ "$(id -u)" -eq 0 ] || { echo "ERROR: must run as root"; exit 1; }
}

detect_paths() {
    for i in $(seq 1 30); do
        E=$(ls /sys/class/drm/card*-HDMI-A-1/edid 2>/dev/null | head -1)
        O=$(ls /sys/kernel/debug/dri/*/HDMI-A-1/edid_override 2>/dev/null | head -1)
        [ -n "$E" ] && [ -n "$O" ] && break
        sleep 1
    done
    S="${E%edid}status"
    if [ -z "$E" ] || [ -z "$O" ]; then
        echo "ERROR: cannot find HDMI-A-1 connector after 30s"
        exit 1
    fi
}

do_switch() {
    detect_paths
    echo "=== HDMI EDID Switch ==="
    echo ""
    if grep -q 'drm.edid_firmware' /proc/cmdline 2>/dev/null; then
        echo "WARNING: Path B mode — switch has no effect."
        echo "  Refreshing PipeWire only..."
        for uid in $(loginctl list-users --no-legend 2>/dev/null | awk '{print $1}'); do
            systemctl --user -M "${uid}@.host" restart pipewire pipewire-pulse wireplumber 2>/dev/null || true
        done
        killall wf-panel-pi 2>/dev/null || true
        return
    fi
    echo -n reset > "$O" 2>/dev/null || true
    echo detect > "$S" 2>/dev/null || true
    sleep 0.5
    TMP=$(mktemp)
    cat "$E" > "$TMP" 2>/dev/null || true
    SZ=$(wc -c < "$TMP")
    rm -f "$TMP"
    if [ "$SZ" -ge 256 ]; then
        echo "Real EDID detected (${SZ}B) — using hardware EDID"
        cat "${E%edid}modes" 2>/dev/null | grep '^[0-9]' | sort -t x -k1 -nr | uniq | head -10
    else
        echo "No real EDID (${SZ}B) — applying fake EDID"
        cat "$F" > "$O" 2>/dev/null
        echo detect > "$S" 2>/dev/null || true
        sleep 0.3
        echo "Modes: $(cat "${E%edid}modes" 2>/dev/null | head -3 | tr '\n' ' ')"
    fi
    for uid in $(loginctl list-users --no-legend 2>/dev/null | awk '{print $1}'); do
        systemctl --user -M "${uid}@.host" restart pipewire pipewire-pulse wireplumber 2>/dev/null || true
    done
    killall wf-panel-pi 2>/dev/null || true
    echo "Audio services refreshed."
}

# ─── config ───────────────────────────────────────────────────
_CONFIG_ACTIVE=()
_CONFIG_PRESET=()
_CONFIG_PREF_IDX=2

do_config() {
    need_root
    _cfg_init
    _cfg_loop
}

_cfg_init() {
    _CONFIG_ACTIVE=(
        "3840x2160@60|4k60"
        "3840x2160@30|4k30"
        "1920x1080@60|1080p60"
        "1920x1080@50|1080p50"
        "1280x720@60|720p60"
        "2560x1440@60|1440p60"
        "1280x800@60|800p60"
        "1920x1200@60|1200p60"
        "1024x768@60|x1024p60"
    )
    _CONFIG_PREF_IDX=2
    _CONFIG_PRESET=(
        "3840x2160@50|4k50"
        "3840x2160@25|4k25"
        "3840x2160@24|4k24"
        "1920x1080@30|1080p30"
        "1920x1080@25|1080p25"
        "1920x1080@24|1080p24"
        "1920x1080i@60|1080i60"
        "1920x1080i@50|1080i50"
        "1280x720@50|720p50"
        "2560x1600@60|1600p60"
        "2560x1080@60|uw1080p60"
        "3440x1440@60|uw1440p60"
        "1600x1200@60|uxga60"
        "1600x900@60|900p60_1600"
        "1440x900@60|900p60"
        "1680x1050@60|1050p60"
        "1360x768@60|768p60"
        "1280x1024@60|sxga60"
        "1280x1024@75|sxga75"
        "640x480@60|480p60"
        "720x480@60|480p60_720"
    )
}

_cfg_loop() {
    while true; do
        _cfg_show
        echo "  1) Delete resolution(s)"
        echo "  2) Add from preset library"
        echo "  3) Custom WxH@Hz"
        echo "  4) Read external EDID (I2C)"
        echo "  5) Set preferred"
        echo "  6) Restore defaults"
        echo "  7) Save & quit"
        echo "  8) Quit (discard changes)"
        echo ""
        printf "Enter choice [1-8]: "
        read -r choice
        case "$choice" in
            1) _cfg_delete ;;
            2) _cfg_add ;;
            3) _cfg_custom ;;
            4) _cfg_read ;;
            5) _cfg_pref ;;
            6) _cfg_reset_cfm ;;
            7) _cfg_save; break ;;
            8) _cfg_quit ;;
            *) echo "Invalid choice."; read -p "Press Enter..."; ;;
        esac
    done
}

_cfg_show() {
    clear 2>/dev/null || true
    echo "=== HDMI EDID Config ==="
    if grep -q 'drm.edid_firmware' /proc/cmdline 2>/dev/null; then
        local mode="Path B (drm.edid_firmware)"
    else
        local mode="Path A (runtime switch)"
    fi
    local pl="${_CONFIG_ACTIVE[$_CONFIG_PREF_IDX]%%|*}"
    echo "Mode: $mode  |  ${#_CONFIG_ACTIVE[@]} modes  |  Preferred: $pl"
    echo ""
    local i
    for i in "${!_CONFIG_ACTIVE[@]}"; do
        local label="${_CONFIG_ACTIVE[$i]%%|*}"
        local mark=" "
        [ "$i" -eq "$_CONFIG_PREF_IDX" ] && mark="*"
        printf "  [%2d] %-24s %s\n" $((i+1)) "$label" "$mark"
    done
    echo ""
}

_cfg_delete() {
    [ ${#_CONFIG_ACTIVE[@]} -le 1 ] && { echo "Need at least 1 mode."; read -p "Press Enter..."; return; }
    echo ""
    echo "Delete — enter numbers to remove (e.g. 1,3,5-7) or 0 to cancel:"
    printf "> "
    read -r nums
    [ -z "$nums" ] || [ "$nums" = "0" ] && return

    local td=()
    local IFS=','; local parts=($nums); unset IFS
    local part
    for part in "${parts[@]}"; do
        if [[ "$part" =~ ^([0-9]+)-([0-9]+)$ ]]; then
            local n
            for ((n=${BASH_REMATCH[1]}; n<=${BASH_REMATCH[2]}; n++)); do
                [ "$n" -ge 1 ] && [ "$n" -le "${#_CONFIG_ACTIVE[@]}" ] && td+=($n)
            done
        else
            [ "$part" -ge 1 ] && [ "$part" -le "${#_CONFIG_ACTIVE[@]}" ] && td+=($part)
        fi
    done
    [ ${#td[@]} -eq 0 ] && { echo "No valid entries."; read -p "Press Enter..."; return; }

    # Show what will be deleted
    local sorted=($(printf '%s\n' "${td[@]}" | sort -rn))
    echo -n "Delete: "
    local first=true
    local n
    for n in "${sorted[@]}"; do
        local label="${_CONFIG_ACTIVE[$((n-1))]%%|*}"
        if $first; then first=false; else echo -n ", "; fi
        echo -n "$label"
    done
    echo ""
    printf "Confirm? [y/N]: "
    read -r yn
    [ "${yn,,}" != "y" ] && { echo "Cancelled."; return; }

    # Save entries before deletion for preset restoration
    local saved=("${_CONFIG_ACTIVE[@]}")
    for n in "${sorted[@]}"; do
        local idx=$((n-1))
        local label="${_CONFIG_ACTIVE[$idx]%%|*}"
        unset '_CONFIG_ACTIVE[idx]'
        [ "$idx" -lt "$_CONFIG_PREF_IDX" ] && _CONFIG_PREF_IDX=$((_CONFIG_PREF_IDX-1))
        [ "$idx" -eq "$_CONFIG_PREF_IDX" ] && _CONFIG_PREF_IDX=0
        echo "  Removed: $label"
        # Add back to preset
        local entry="${saved[$idx]}"
        local already=false
        local p
        for p in "${_CONFIG_PRESET[@]}"; do
            [ "$p" = "$entry" ] && already=true && break
        done
        if ! $already; then
            _CONFIG_PRESET+=("$entry")
        fi
    done
    _CONFIG_ACTIVE=("${_CONFIG_ACTIVE[@]}")
    read -p "Press Enter..."
}

_cfg_add() {
    echo ""
    echo "Preset library (not yet active):"
    local i count=0
    local disp_idx=0
    local pmap=()
    for i in "${!_CONFIG_PRESET[@]}"; do
        local entry="${_CONFIG_PRESET[$i]}"
        local found=false
        local a
        for a in "${_CONFIG_ACTIVE[@]}"; do
            [ "$a" = "$entry" ] && found=true && break
        done
        if ! $found; then
            count=$((count+1))
            disp_idx=$((disp_idx+1))
            pmap[$disp_idx]=$i
            printf "  [%2d] %s\n" $disp_idx "${entry%%|*}"
        fi
    done
    [ $count -eq 0 ] && { echo "  (all presets already active)"; read -p "Press Enter..."; return; }
    echo ""
    echo "Enter numbers to add (e.g. 1,3,5-7) or 0 to cancel:"
    printf "> "
    read -r nums
    [ -z "$nums" ] || [ "$nums" = "0" ] && return

    local ta=()
    local IFS=','; local parts=($nums); unset IFS
    local part
    for part in "${parts[@]}"; do
        if [[ "$part" =~ ^([0-9]+)-([0-9]+)$ ]]; then
            local n
            for ((n=${BASH_REMATCH[1]}; n<=${BASH_REMATCH[2]}; n++)); do
                [ -n "${pmap[$n]+x}" ] && ta+=(${pmap[$n]})
            done
        else
            [ -n "${pmap[$part]+x}" ] && ta+=(${pmap[$part]})
        fi
    done
    [ ${#ta[@]} -eq 0 ] && { echo "No valid entries."; read -p "Press Enter..."; return; }

    local n
    for n in "${ta[@]}"; do
        local entry="${_CONFIG_PRESET[$n]}"
        _CONFIG_ACTIVE+=("$entry")
        echo "  Added: ${entry%%|*}"
    done
    read -p "Press Enter..."
}

_cfg_custom() {
    echo ""
    printf "Width: "; read -r w
    printf "Height: "; read -r h
    printf "Refresh (Hz): "; read -r hz
    [ -z "$w" ] || [ -z "$h" ] || [ -z "$hz" ] && return
    local key="custom_${w}x${h}x${hz}"
    local label="${w}x${h}@${hz}"
    _CONFIG_ACTIVE+=("$label|$key")
    _CONFIG_PRESET+=("$label|$key")
    echo "  Added: $label"
    read -p "Press Enter..."
}

_cfg_read() {
    echo ""
    echo "Reading external EDID via I2C..."
    local ddc=""
    local bus
    for bus in 13 11 14; do
        if i2cdetect -y $bus 0x50 0x50 2>/dev/null | grep -q 50; then
            ddc=$bus; break
        fi
    done
    if [ -z "$ddc" ]; then
        echo "ERROR: No DDC bus found. Is display connected?"
        read -p "Press Enter..."
        return
    fi
    echo "  DDC bus: $ddc"
    echo ""
    local result
    result=$(python3 /usr/local/bin/hdmi-edid-merge "$ddc" 2>&1)
    echo "$result"
    echo ""
    echo "  1) Merge — combine external + current"
    echo "  2) Replace — use external resolutions"
    echo "  3) Cancel"
    printf "Choice [1-3]: "
    read -r rc
    case "$rc" in
        1) echo "Merge selected. (Full merge logic pending.)" ;;
        2) echo "Replace selected. (Full replace logic pending.)" ;;
        *) echo "Cancelled."; return ;;
    esac
    read -p "Press Enter..."
}

_cfg_pref() {
    echo ""
    printf "Set preferred — enter number [1-${#_CONFIG_ACTIVE[@]}]: "
    read -r n
    [ -z "$n" ] && return
    [ "$n" -ge 1 ] && [ "$n" -le "${#_CONFIG_ACTIVE[@]}" ] || { echo "Invalid number."; read -p "Press Enter..."; return; }
    _CONFIG_PREF_IDX=$((n-1))
    echo "Preferred: ${_CONFIG_ACTIVE[$_CONFIG_PREF_IDX]%%|*}"
    read -p "Press Enter..."
}

_cfg_reset_cfm() {
    echo ""
    printf "Restore factory defaults? This will reset all changes. [y/N]: "
    read -r yn
    [ "${yn,,}" != "y" ] && { echo "Cancelled."; return; }
    _cfg_init
    echo "Restored factory defaults."
    read -p "Press Enter..."
}

_cfg_quit() {
    echo ""
    printf "Quit without saving? Changes will be lost. [y/N]: "
    read -r yn
    [ "${yn,,}" = "y" ] && { echo "Quit."; exit 0; }
}

_cfg_save() {
    local pref_key="${_CONFIG_ACTIVE[$_CONFIG_PREF_IDX]##*|}"
    local keys=""
    local entry
    for entry in "${_CONFIG_ACTIVE[@]}"; do
        local k="${entry##*|}"
        [ -z "$keys" ] && keys="$k" || keys="$keys,$k"
    done
    python3 /usr/local/bin/hdmi-edid-gen "$pref_key" "$keys"
    echo "EDID saved."
    if grep -q 'drm.edid_firmware' /proc/cmdline 2>/dev/null; then
        echo "Reboot required to apply changes."
    else
        echo "Run 'hdmi-edid switch' or reboot to apply."
    fi
}

# ─── uninstall ─────────────────────────────────────────────────
do_uninstall() {
    detect_paths
    echo "=== HDMI EDID Uninstall ==="
    echo ""
    if [ -f "${CMDLINE}.bak" ]; then
        cp "${CMDLINE}.bak" "$CMDLINE"
    else
        sed -i 's/ vc4.force_hotplug=1//' "$CMDLINE"
        sed -i 's/ drm.edid_firmware=HDMI-A-1:edid-hdmi-audio.bin//' "$CMDLINE"
    fi
    echo "[1/4] cmdline restored"
    sed -i '/^hdmi_force_hotplug=1/d' "$CONFIG_TXT" 2>/dev/null || true
    echo "[2/4] config.txt cleaned"
    systemctl disable hdmi-edid-boot.service 2>/dev/null || true
    systemctl stop hdmi-edid-boot.service 2>/dev/null || true
    rm -f /etc/systemd/system/hdmi-edid-boot.service
    systemctl daemon-reload
    echo "[3/4] service removed"
    echo -n reset > "$O" 2>/dev/null || true
    echo detect > "$S" 2>/dev/null || true
    echo "[4/4] EDID override cleared"
    echo ""
    echo "Uninstall complete. Reboot to fully apply."
}

case "${1:-}" in
    switch)   need_root; do_switch ;;
    config)   do_config ;;
    uninstall) need_root; do_uninstall ;;
    *)        usage ;;
esac